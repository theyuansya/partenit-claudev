# Trust Layer Pipeline — environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# On Railway: set these in the Variables tab (never commit .env)

# ── Server ────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — leave commented out there
# PORT=8090
WEBHOOK_SECRET=change-me-to-random-string

# ── Claude Code (AI worker) ───────────────────────────────────────────────────
# Railway / any cloud server: set your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...
#
# Local Docker with Max subscription: leave blank, mount ~/.claude in docker-compose.yml
# Any server without local mount: base64-encode your ~/.claude folder and paste here:
#   tar -czf - ~/.claude | base64 -w0
# CLAUDE_AUTH_JSON=

# ── DeepSeek (orchestrator / classifier / label suggester) ───────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Jira Cloud ────────────────────────────────────────────────────────────────
# JIRA_DOMAIN: subdomain only, e.g. "mycompany" for mycompany.atlassian.net
JIRA_DOMAIN=mycompany
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=...
JIRA_PROJECT_KEY=TRUST

# ── GitHub (the repo Claude Code will work on) ────────────────────────────────
# Token needs: repo (read + write + pull_requests)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/trust-layer

# ── Pipeline behaviour ────────────────────────────────────────────────────────
TRIGGER_STATUS=In Progress
STAGE_BRANCH=stage
MAX_CONCURRENT_JOBS=3
JOB_TIMEOUT_MINUTES=30

# ── Jira status names (must match your workflow exactly) ──────────────────────
STATUS_TODO=To Do
STATUS_IN_PROGRESS=In Progress
STATUS_DONE=Done
STATUS_READY_FOR_TEST=Ready for Test
STATUS_IN_REVIEW=In Review

